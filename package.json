{
  "name": "royal-wedding",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "rimraf .next node_modules/.cache",
    "clean:build": "npm run clean && npm run build",
    "dev:clean": "npm run clean && npm run dev",
    "dev:fresh": "npm run dev:clean",
    "seed:demo": "node --env-file=.env.local scripts/seed-demo.mjs",
    "generate:premium-preset": "node scripts/generate-premium-preset.mjs",
    "seed:premium-template": "node scripts/generate-premium-preset.mjs && node --env-file=.env.local scripts/seed-premium-template.mjs",
    "seed:templates": "node --env-file=.env.local scripts/seed-imported-templates.mjs",
    "import:mehappy-html": "node --env-file=.env.local scripts/import-mehappy-html.mjs",
    "generate:mehappy-craft": "node scripts/generate-mehappy-craft-templates.mjs",
    "reseed:mehappy-craft": "node --env-file=.env.local scripts/reseed-mehappy-craft.mjs",
    "validate:premium-preset": "node scripts/validate-premium-preset.mjs"
  },
  "dependencies": {
    "@craftjs/core": "^0.2.12",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@payos/node": "^2.0.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "animate.css": "^4.1.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "next": "14.2.35",
    "qrcode.react": "^4.2.0",
    "react": "^18",
    "react-countdown": "^2.3.6",
    "react-dom": "^18",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.75.0",
    "react-moveable": "^0.56.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "swiper": "^11.2.10",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.21",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "rimraf": "^5.0.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
